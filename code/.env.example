# ============================================================
# .env.example — sample environment variables for this agent.
# Copy this file to .env and fill in the real values before
# running the agent.
# ============================================================

# ── General Configuration ───────────────────────────────
AZURE_AI_SEARCH_INDEX=policy-index
AZURE_AI_SEARCH_KEY=your-value-here
AZURE_CLIENT_ID=your-value-here
AZURE_TENANT_ID=your-value-here
ENVIRONMENT=development
KNOWLEDGE_BASE_DOCUMENT_LIST=[]
LLM_MODEL=gpt-4.1
LLM_PROVIDER=openai
LLM_SYSTEM_PROMPT=You are the Company Policy Q&A Agent. Your role is to answer employee questions about company policies, HR procedures, and handbook content using only the official, indexed documents. Every answer must cite the source document, section, and last-updated date. If you are not confident in your answer or the topic is sensitive or legal, escalate to the appropriate specialist. Never fabricate details or provide legal advice. Keep answers concise and professional, and offer more detail if requested.
LLM_TEMPERATURE=0.7
LLM_USER_PROMPT_TEMPLATE=Please enter your question about company policies, HR procedures, or the employee handbook. For example: 
OBS_AZURE_SQL_DATABASE=your-value-here
OBS_AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server
OBS_AZURE_SQL_SCHEMA=dbo
OBS_AZURE_SQL_SERVER=your-value-here
OBS_AZURE_SQL_USERNAME=your-value-here
OBS_DATABASE_TYPE=sqlite
OBS_SQLITE_PATH=observability.db
SERVICE_NAME=agent
SERVICE_VERSION=1.0.0
SESSION_TTL_SECONDS=86400

# ── Service Endpoints ───────────────────────────────────
AZURE_AI_SEARCH_ENDPOINT=https://your-service.example.com
ESCALATION_API_URL=http://localhost:9000/escalate
HR_ADMIN_API_URL=http://localhost:9000/hradmin
LOGGING_API_URL=http://localhost:9000/log
REDIS_URL=redis://localhost:6379/0

# ── Secrets / API Keys — never commit real values ───────
AZURE_CLIENT_SECRET=your-secret-here
ESCALATION_API_KEY=your-secret-here
FERNET_KEY=your-secret-here
HR_ADMIN_API_KEY=your-secret-here
JWT_SECRET=your-secret-here
LLM_MAX_TOKENS=2000
LOGGING_API_KEY=your-secret-here
OBS_AZURE_SQL_PASSWORD=your-secret-here
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
